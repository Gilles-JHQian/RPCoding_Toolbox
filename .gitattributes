# Normalize line endings to LF in the repo (cross-platform consistency).
* text=auto eol=lf

# Windows scripts need CRLF; Unix shell scripts need LF (a CRLF shebang breaks on macOS/Linux).
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.command text eol=lf
*.sh text eol=lf

# Treat known binary types as binary (no EOL conversion).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mat binary
*.pdf binary
*.npz binary
*.npy binary
