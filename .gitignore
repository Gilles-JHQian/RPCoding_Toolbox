# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# ---- Test / lint / type caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---- Virtual envs (we use a conda env named `rpcoding`, not in-repo) ----
.venv/
venv/
env/

# ---- Editors / OS ----
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- App runtime caches & generated data (never commit subject data) ----
.rpcoding/
*.wav
*.mat
!tests/fixtures/**/*.mat

# MFA output dirs (mfa/, input_mfa*/, output_mfa*/) live in the external subject data tree,
# not in this repo, so they are not ignored here (a broad `mfa/` would wrongly hide the
# tracked source package src/rpcoding/core/mfa/).

# ---- Reference material is kept local-only (see references/.gitignore = '*') ----
